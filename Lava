local traitHookConnection = nil

local function initTraitHook()
    if traitHookConnection then
        traitHookConnection:Disconnect()
        traitHookConnection = nil
    end
    local traitEvent = game:GetService("ReplicatedStorage").Registries.TraitsRegistry.SetupTraitVFX
    traitHookConnection = traitEvent.OnClientEvent:Connect(function(brainrotModel, vfxModule)
        if not brainrotModel or not brainrotModel.Parent then return end

        local traitName = ""
        pcall(function()
            traitName = vfxModule.Name:gsub("VFX$", "")
        end)
        if traitName == "" then return end

        if not traitData[brainrotModel] then
            traitData[brainrotModel] = {
                obj        = brainrotModel,
                traitNames = {},
                name       = brainrotModel:GetAttribute("DisplayName") or brainrotModel.Name,
                rarity     = (brainrotModel.Parent and brainrotModel.Parent.Name) or "Unknown",
                mutation   = brainrotModel:GetAttribute("Mutation") or "Normal",
            }
        end

        local alreadyHas = false
        for _, t in ipairs(traitData[brainrotModel].traitNames) do
            if t == traitName then alreadyHas = true break end
        end
        if not alreadyHas then
            table.insert(traitData[brainrotModel].traitNames, traitName)
        end
    end)
end

