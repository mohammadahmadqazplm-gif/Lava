local mt = getrawmetatable(game)
local old_namecall = mt.__namecall
local old_index = mt.__index
setreadonly(mt, false)

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    if method == "Kick" then
        warn("[oxyo Protection] Blocked kick attempt!")
        return
    end
    if method == "FireServer" or method == "InvokeServer" then
        if typeof(args[1]) == "string" then
            local lowerArg = args[1]:lower()
            if lowerArg:find("kick") or lowerArg:find("ban") or
               lowerArg:find("anticheat") or lowerArg:find("detect") or
               lowerArg:find("flag") or lowerArg:find("report") then
                warn("[oxyo Protection] Blocked suspicious remote call!")
                return
            end
        end
    end
    return old_namecall(self, ...)
end)

mt.__index = newcclosure(function(self, key)
    local result = old_index(self, key)
    if self:IsA("Humanoid") and (key == "WalkSpeed" or key == "JumpPower") then
        if key == "WalkSpeed" and result > 16 then return 16
        elseif key == "JumpPower" and result > 50 then return 50
        end
    end
    return result
end)

setreadonly(mt, true)

