    for _, v in pairs(workspace:GetDescendants()) do
        if v.Name == "Lavas" or v.Name == "Lava" then pcall(function() v:Destroy() end) end
    end
    lavaRemoved = true
end
local function restoreLava() lavaRemoved = false end

local function getBrainrotFolder(rarity)
    if rarity == "Godly" then
        local br = workspace:FindFirstChild("Brainrots")
        return br and br:FindFirstChild("Godly")
    end
    local gf = workspace:FindFirstChild("GameFolder")
    if not gf then return nil end
    local br = gf:FindFirstChild("Brainrots")
    return br and br:FindFirstChild(rarity)
end

local function passesFarmFilters(obj)
    if #selectedMutations > 0 then
        local mutation = obj:GetAttribute("Mutation") or "Normal"
        local mutOk = false
        for _, m in ipairs(selectedMutations) do
            if mutation == m then mutOk = true break end
        end
        if not mutOk then return false end
    end
    if #selectedTraits > 0 then
        local td = traitData[obj]
        if not td or #td.traitNames == 0 then return false end
        local traitOk = false
        for _, wantedTrait in ipairs(selectedTraits) do
            for _, haveTrait in ipairs(td.traitNames) do
                if wantedTrait == haveTrait then traitOk = true break end
            end
            if traitOk then break end
        end
        if not traitOk then return false end
    end
    return true
end

local function passesByNameFilter(obj)
    if farmByNameFilter == "" then return false end
    local displayName = (obj:GetAttribute("DisplayName") or obj.Name):lower()
    return displayName:find(farmByNameFilter:lower(), 1, true) ~= nil
end

local function passesFilters(obj)
    return passesFarmFilters(obj)
end

local function pickFromFolder(folder)
    for _, obj in ipairs(folder:GetChildren()) do
        if passesFarmFilters(obj) then return obj end
    end
    return nil
end

local function grabBrainrot(obj)
    if not obj or not obj.Parent then return false end
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return false end

    local part = obj:FindFirstChildWhichIsA("BasePart") or obj.PrimaryPart
    if not part then return false end

    safeTeleport(part.CFrame * CFrame.new(0, 4, 0))
    task.wait(0.5)

    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
    if prompt then
        local originalHold = prompt.HoldDuration
        pcall(function() prompt.HoldDuration = 0 end)
        pcall(function() fireproximityprompt(prompt) end)
        local holdTime = math.max(originalHold, 0.7)
        task.wait(holdTime)
        pcall(function() prompt.HoldDuration = originalHold end)
        task.wait(0.5)
    end
    return true
end

local function submitAndPlace()
    pcall(function()
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local TWEEN_TARGET = Vector3.new(-34.304245, 4.346454, -44.978447)
            local t1 = TweenService:Create(root, TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {CFrame = CFrame.new(TWEEN_TARGET)})
            t1:Play()
            t1.Completed:Wait()
            local t2 = TweenService:Create(root, TweenInfo.new(0.15, Enum.EasingStyle.Linear), {CFrame = CFrame.new(TWEEN_TARGET - Vector3.new(0, 1.3, 0))})
            t2:Play()
            t2.Completed:Wait()
        end
    end)
    task.wait(0.5)

    local success = teleportToMyPlot()
    if not success then task.wait(1) return end
    task.wait(0.6)

    pcall(function()
        local equipBest = game:GetService("ReplicatedStorage"):WaitForChild("Events", 5):WaitForChild("EquipBest", 5)
        if equipBest then equipBest:FireServer() end
    end)
    task.wait(0.4)

    pcall(function()
        local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        for _ = 1, maxCarry do
            local best, bestDist = nil, 20
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ProximityPrompt") and v.Name:lower():find("place") then
                    local p = v.Parent
                    if p and p:IsA("BasePart") then
                        local d = (p.Position - root.Position).Magnitude
                        if d < bestDist then best = v bestDist = d end
                    end
                end
            end
            if best then
                fireproximityprompt(best)
                task.wait(0.5)
            else
                break
            end
        end
    end)
    task.wait(0.5)
end

local function collectOne(rarity, objOverride)
    local folder = getBrainrotFolder(rarity)
    if not folder then return end
    local obj = objOverride
    if not obj or not obj.Parent then obj = pickFromFolder(folder) end
    if not obj or not obj.Parent then return end
    if grabBrainrot(obj) then
        submitAndPlace()
    end
end

local stopFarmLoop

local function startFarm(rarities)
    if collectorRunning then stopFarmLoop() task.wait(0.1) end
    collectorRunning = true
    hideLava()

    pcall(function()
        game:GetService("ReplicatedStorage").Events.Carry:InvokeServer(maxCarry)
    end)

    collectorThread = task.spawn(function()
        while collectorRunning do
            if grabLock then task.wait(0.2) continue end

            local snapshot = monitorData.brainrots
            local raritySet = {}
            for _, r in ipairs(rarities) do raritySet[r] = true end

            local targets = {}
            for _, entry in ipairs(snapshot) do
                if raritySet[entry.rarity] and entry.obj and entry.obj.Parent then
                    if passesFarmFilters(entry.obj) then
                        table.insert(targets, entry)
                    end
                end
            end

            table.sort(targets, function(a, b)
                return (RARITY_ORDER[a.rarity] or 99) < (RARITY_ORDER[b.rarity] or 99)
            end)

            if #targets == 0 then
                task.wait(1)
                continue
            end

            local grabbed = 0
            for _, entry in ipairs(targets) do
                if not collectorRunning then break end
                if grabLock then break end
                if grabbed >= maxCarry then break end
                if entry.obj and entry.obj.Parent then
                    local ok, didGrab = pcall(grabBrainrot, entry.obj)
                    if ok and didGrab then
                        grabbed = grabbed + 1
                    end
                end
            end

            if grabbed > 0 and collectorRunning and not grabLock then
                pcall(submitAndPlace)
            end

            task.wait(0.2)
        end
    end)
end

stopFarmLoop = function()
    collectorRunning = false
    if collectorThread then task.cancel(collectorThread) collectorThread = nil end
    restoreLava()
end

