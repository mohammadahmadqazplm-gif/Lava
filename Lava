BrainrotStatusTab:CreateSection("Mutation Alert")

local mutationAlertEnabled  = false
local mutationAlertThread   = nil
local ALERT_MUTATIONS       = {"Gold","Emerald","Diamond","Cheese","Bloodmoon","Rainbow"}
local mutationAlertDropdown = {}

BrainrotStatusTab:CreateDropdown({
    Name            = "Alert for Mutations",
    Options         = ALERT_MUTATIONS,
    CurrentOption   = {},
    MultipleOptions = true,
    Flag            = "MutationAlertDropdown",
    Callback        = function(Options) mutationAlertDropdown = Options end,
})

BrainrotStatusTab:CreateToggle({
    Name         = "Mutation Alert",
    CurrentValue = false,
    Flag         = "MutationAlert",
    Callback     = function(Value)
        mutationAlertEnabled = Value
        if Value then
            local lastSeen = {}
            mutationAlertThread = task.spawn(function()
                while mutationAlertEnabled do
                    pcall(function()
                        for _, e in ipairs(monitorData.mutations) do
                            if e.obj and e.obj.Parent then
                                local alertSet = {}
                                for _, m in ipairs(mutationAlertDropdown) do alertSet[m] = true end
                                local shouldAlert = (#mutationAlertDropdown == 0) or alertSet[e.mutation]
                                local key = e.name .. "_" .. e.mutation .. "_" .. e.rarity
                                if shouldAlert and not lastSeen[key] then
                                    lastSeen[key] = true
                                    warn("[oxyo] MUTATION: [" .. e.mutation .. "] " .. e.name .. " @ " .. e.rarity)
                                    Rayfield:Notify({
                                        Title    = "Mutation Detected!",
                                        Content  = "[" .. e.mutation .. "] " .. e.name .. "\nZone: " .. e.rarity,
                                        Duration = 6,
                                        Image    = 4483362458,
                                    })
                                end
                            end
                        end
                        local alive = {}
                        for _, e in ipairs(monitorData.mutations) do
                            alive[e.name .. "_" .. e.mutation .. "_" .. e.rarity] = true
                        end
                        for k in pairs(lastSeen) do
                            if not alive[k] then lastSeen[k] = nil end
                        end
                    end)
                    task.wait(0.5)
                end
            end)
        else
            if mutationAlertThread then
                task.cancel(mutationAlertThread)
                mutationAlertThread = nil
            end
        end
    end,
})

task.spawn(function()
    while true do
        task.wait(0.5)
        pcall(function()
            local snapshot = monitorData.brainrots
            local lines    = {}

            if #snapshot == 0 then
                pcall(function()
                    statusParagraph:Set({
                        Title   = "Brainrots in World (0)",
                        Content = "No Brainrots in world right now.",
                    })
                end)
                return
            end

            for _, entry in ipairs(snapshot) do
                if entry.obj and entry.obj.Parent then
                    local traitStr = ""
                    local td = traitData[entry.obj]
                    if td and #td.traitNames > 0 then
                        traitStr = " [TRAIT: " .. table.concat(td.traitNames, "+") .. "]"
                    end
                    table.insert(lines, "[" .. entry.rarity .. "] " .. entry.name .. " — " .. entry.mutation .. traitStr)
                end
            end

            pcall(function()
                statusParagraph:Set({
                    Title   = "Brainrots in World (" .. #lines .. ")",
                    Content = #lines > 0 and table.concat(lines, "\n") or "Nothing right now.",
                })
            end)
        end)
    end
end)

